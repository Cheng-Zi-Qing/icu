"""AI 配置界面"""
from PySide6.QtWidgets import (QDialog, QVBoxLayout, QLabel, QPushButton,
                                QRadioButton, QLineEdit, QHBoxLayout, QComboBox)
from PySide6.QtCore import Qt
import json
import requests
from pathlib import Path


class AIConfigDialog(QDialog):
    """AI 配置对话框"""

    def __init__(self, parent=None):
        super().__init__(parent)
        self.setWindowFlags(Qt.FramelessWindowHint | Qt.Dialog)
        self.config_file = Path('config/settings.json')
        self.setup_ui()
        self.load_config()

    def setup_ui(self):
        """设置UI"""
        self.setWindowTitle("AI 配置")
        self.setFixedSize(550, 450)

        # 像素风格样式
        self.setStyleSheet("""
            QDialog {
                background-color: #2b2b2b;
            }
            QLabel {
                color: #e0e0e0;
                font-family: 'Courier New', monospace;
                font-size: 13px;
            }
            QRadioButton {
                color: #e0e0e0;
                font-family: 'Courier New', monospace;
            }
            QLineEdit, QComboBox {
                background-color: #3a3a3a;
                color: #00ff00;
                border: 3px solid #5a5a5a;
                border-style: inset;
                padding: 5px;
                font-family: 'Courier New', monospace;
            }
            QPushButton {
                background-color: #3a3a3a;
                color: #e0e0e0;
                border: 3px solid #5a5a5a;
                border-style: outset;
                padding: 10px 20px;
                font-family: 'Courier New', monospace;
            }
            QPushButton:hover {
                background-color: #4a4a4a;
            }
            QPushButton:pressed {
                border-style: inset;
            }
        """)

        layout = QVBoxLayout()

        # 标题
        title = QLabel("AI 文案生成配置")
        title.setStyleSheet("font-size: 16px; font-weight: bold;")
        layout.addWidget(title)

        layout.addSpacing(20)

        # 模式选择
        layout.addWidget(QLabel("生成模式："))
        self.simple_radio = QRadioButton("简单模式（固定文案）")
        self.ai_radio = QRadioButton("AI 模式（本地 Ollama）")
        self.simple_radio.setChecked(True)
        self.simple_radio.toggled.connect(self.update_ui_state)
        layout.addWidget(self.simple_radio)
        layout.addWidget(self.ai_radio)

        layout.addSpacing(20)

        # Ollama 配置
        layout.addWidget(QLabel("Ollama 配置："))
        
        url_layout = QHBoxLayout()
        url_layout.addWidget(QLabel("API 地址："))
        self.url_input = QLineEdit("http://localhost:11434")
        url_layout.addWidget(self.url_input)
        layout.addLayout(url_layout)

        model_layout = QHBoxLayout()
        model_layout.addWidget(QLabel("模型："))
        self.model_combo = QComboBox()
        self.model_combo.setEditable(True)
        model_layout.addWidget(self.model_combo)

        self.refresh_btn = QPushButton("刷新")
        self.refresh_btn.clicked.connect(self.load_models)
        model_layout.addWidget(self.refresh_btn)
        layout.addLayout(model_layout)

        # 测试按钮
        self.test_btn = QPushButton("测试连接")
        self.test_btn.clicked.connect(self.test_connection)
        layout.addWidget(self.test_btn)

        self.status_label = QLabel("")
        layout.addWidget(self.status_label)

        layout.addStretch()

        # 保存按钮
        btn_layout = QHBoxLayout()
        save_btn = QPushButton("保存")
        cancel_btn = QPushButton("取消")
        save_btn.clicked.connect(self.save_config)
        cancel_btn.clicked.connect(self.reject)
        btn_layout.addStretch()
        btn_layout.addWidget(cancel_btn)
        btn_layout.addWidget(save_btn)
        layout.addLayout(btn_layout)

        self.setLayout(layout)
        self.update_ui_state()

    def update_ui_state(self):
        """根据模式更新UI状态"""
        ai_enabled = self.ai_radio.isChecked()
        self.url_input.setEnabled(ai_enabled)
        self.model_combo.setEnabled(ai_enabled)
        self.refresh_btn.setEnabled(ai_enabled)
        self.test_btn.setEnabled(ai_enabled)

    def load_config(self):
        """加载配置"""
        if self.config_file.exists():
            with open(self.config_file, 'r') as f:
                config = json.load(f)
                ai_config = config.get('ai', {})

                if ai_config.get('mode') == 'local':
                    self.ai_radio.setChecked(True)

                local_api = ai_config.get('local_api', {})
                if local_api.get('url'):
                    self.url_input.setText(local_api['url'])

                # 加载模型列表
                self.load_models()

                # 设置当前模型
                if local_api.get('model'):
                    self.model_combo.setCurrentText(local_api['model'])

        self.update_ui_state()

    def load_models(self):
        """从 Ollama 加载模型列表"""
        self.model_combo.clear()
        self.status_label.setText("正在加载模型...")
        self.status_label.setStyleSheet("color: blue;")
        try:
            url = self.url_input.text().rstrip('/')
            response = requests.get(
                f"{url}/api/tags",
                timeout=2,
                proxies={'http': None, 'https': None}
            )
            if response.status_code == 200:
                models = response.json().get('models', [])
                for model in models:
                    self.model_combo.addItem(model['name'])
                if self.model_combo.count() == 0:
                    self.model_combo.addItem("qwen2.5:7b")
                    self.status_label.setText("未找到模型，使用默认")
                else:
                    self.status_label.setText(f"✅ 加载了 {len(models)} 个模型")
                    self.status_label.setStyleSheet("color: green;")
            else:
                self.model_combo.addItem("qwen2.5:7b")
                self.status_label.setText(f"❌ HTTP {response.status_code}")
                self.status_label.setStyleSheet("color: red;")
        except requests.exceptions.Timeout:
            self.model_combo.addItem("qwen2.5:7b")
            self.status_label.setText("❌ 连接超时")
            self.status_label.setStyleSheet("color: red;")
        except requests.exceptions.ConnectionError:
            self.model_combo.addItem("qwen2.5:7b")
            self.status_label.setText("❌ 无法连接到 Ollama")
            self.status_label.setStyleSheet("color: red;")
        except Exception as e:
            self.model_combo.addItem("qwen2.5:7b")
            self.status_label.setText(f"❌ {type(e).__name__}: {str(e)[:50]}")
            self.status_label.setStyleSheet("color: red;")

    def test_connection(self):
        """测试 Ollama 连接"""
        from src.ollama_client import OllamaClient
        
        client = OllamaClient(self.url_input.text(), self.model_combo.currentText())
        if client.is_available():
            self.status_label.setText("✅ 连接成功")
            self.status_label.setStyleSheet("color: green;")
        else:
            self.status_label.setText("❌ 连接失败，请检查 Ollama 是否启动")
            self.status_label.setStyleSheet("color: red;")

    def save_config(self):
        """保存配置"""
        with open(self.config_file, 'r') as f:
            config = json.load(f)
        
        config['ai'] = {
            'mode': 'local' if self.ai_radio.isChecked() else 'fixed',
            'local_api': {
                'enabled': self.ai_radio.isChecked(),
                'url': self.url_input.text(),
                'model': self.model_combo.currentText()
            }
        }
        
        with open(self.config_file, 'w') as f:
            json.dump(config, f, indent=2)
        
        self.accept()
