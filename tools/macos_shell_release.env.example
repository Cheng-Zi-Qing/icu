# macOS shell release environment template
# Edit the values below, then load them before packaging:
#
#   set -a
#   source tools/macos_shell_release.env
#   set +a
#   ./icu --package-app
#
# Or for a full release smoke check + package run:
#
#   set -a
#   source tools/macos_shell_release.env
#   set +a
#   ./icu --verify
#   ./icu --package-app

export ICU_PACKAGE_APP_NAME="ICU"
export ICU_PACKAGE_APP_VERSION="1.0.0"
export ICU_PACKAGE_BUNDLE_ID="ai.wiz.icu.shell"

# Required for signing and notarization.
export ICU_PACKAGE_SIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"

# Enable notarization only after the notarytool profile exists locally.
export ICU_PACKAGE_NOTARIZE="0"
export ICU_NOTARYTOOL_PROFILE="icu-notary"

# Enable pre-release verification stages.
export VERIFY_MACOS_SHELL_PACKAGE_CHECK="1"
export VERIFY_MACOS_SHELL_RUNTIME_SMOKE_CHECK="1"
# export VERIFY_MACOS_SHELL_RUNTIME_SMOKE_SCRIPT="tools/smoke_test_macos_app_runtime.sh"

# Optional binary overrides.
# export ICU_PACKAGE_SWIFT_BIN="swift"
# export ICU_PACKAGE_CODESIGN_BIN="codesign"
# export ICU_PACKAGE_XCRUN_BIN="xcrun"
